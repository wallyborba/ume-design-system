      "300": { "$value": "#B88FFE", "$type": "color" },
      "400": { "$value": "#974AFD", "$type": "color" },
      "500": { "$value": "#7B30E0", "$type": "color" },
      "600": { "$value": "#6020B8", "$type": "color" },
      "700": { "$value": "#4A1890", "$type": "color" },
      "800": { "$value": "#351068", "$type": "color" },
      "900": { "$value": "#200A40", "$type": "color" }
    },
    "gray": {
