{
  "$description": "Ume Design System Tokens v2.1 — shadcn/ui + Brand Identity + Dark Mode + Functional States",
  "$version": "2.1.0",
  "color": {
    "brand": {
      "cinza-escuro": { "$value": "#1A1A1A", "$type": "color", "$description": "Dark Gray — Default text, dark backgrounds" },
      "verde-escuro": { "$value": "#014751", "$type": "color", "$description": "Dark Green — Authority, section headers, sidebar, institutional" },
      "verde-medio": { "$value": "#038C52", "$type": "color", "$description": "Medium Green — Active states, success, highlight blocks" },
      "verde-claro": { "$value": "#09CF7C", "$type": "color", "$description": "Light Green — Primary CTA, accent, emphasis, overlines" },
      "roxo": { "$value": "#974AFD", "$type": "color", "$description": "Purple — Links, secondary actions, focus ring" },
