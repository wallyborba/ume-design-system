      "glass": { "background": "rgba(255,255,255,0.08)", "border": "1px solid rgba(255,255,255,0.1)", "backdropBlur": "12px", "borderRadius": "{borderRadius.lg}", "padding": "24px", "$description": "Glass card — use over gradients" },
      "gradient-border": { "background": "#FFFFFF", "border": "1px gradient (green→teal→purple)", "shadow": "none", "borderRadius": "{borderRadius.lg}", "padding": "24px", "$description": "Card with gradient border — brand highlight" },
      "gradient-top": { "background": "#FFFFFF", "border": "1px solid #E5E5E5", "borderTop": "3px gradient (green→purple)", "shadow": "none", "borderRadius": "{borderRadius.lg}", "padding": "24px", "$description": "Card with gradient top accent" }
