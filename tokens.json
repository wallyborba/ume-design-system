      "elevated": { "background": "#FFFFFF", "border": "none", "shadow": "{boxShadow.md}", "borderRadius": "{borderRadius.lg}", "padding": "24px" },
      "dark": { "background": "#1A1A1A", "border": "none", "shadow": "none", "borderRadius": "{borderRadius.lg}", "padding": "24px" },
